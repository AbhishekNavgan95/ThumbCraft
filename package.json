{
  "name": "thumbcraft",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev --filter=./apps/* --parallel",
    "dev:watch": "turbo run dev --parallel",
    "dev:stop": "node infra/scripts/kill-dev-ports.mjs",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:bootstrap": "node infra/scripts/bootstrap-rabbitmq.mjs"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "amqplib": "^0.10.5",
    "turbo": "^2.10.5"
  }
}
