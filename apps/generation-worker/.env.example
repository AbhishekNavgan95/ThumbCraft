NODE_ENV=development
PORT=3003
LOG_LEVEL=info
SERVICE_NAME=generation-worker
DATABASE_URL=postgresql://thumbcraft:thumbcraft@localhost:5432/generation_db
RABBITMQ_URL=amqp://guest:guest@localhost:5672
REDIS_URL=redis://localhost:6379
WALLET_SERVICE_URL=http://localhost:3002

# AI providers
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_ENHANCE_MODEL=gpt-5-mini

# Amazon S3 (image refs + generated thumbnails)
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# Optional when using IAM role / shared credentials file
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional CDN / public base (no trailing slash). Falls back to virtual-hosted S3 URL.
# AWS_S3_PUBLIC_BASE_URL=https://cdn.example.com

# Skip real Gemini/OpenAI image calls — placeholder image for flow testing
FAKE_IMAGE_GENERATION=false
