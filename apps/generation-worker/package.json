{
  "name": "@thumbcraft/generation-worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "prisma generate && tsx watch --clear-screen=false --exclude \"../../packages/**\" src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "typecheck": "prisma generate && tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:push": "prisma db push",
    "db:deploy": "prisma migrate deploy",
    "db:seed:models": "tsx prisma/seed-models.ts"
  },
  "dependencies": {
    "@platform/config": "workspace:*",
    "@platform/errors": "workspace:*",
    "@platform/logger": "workspace:*",
    "@platform/messaging-contract": "workspace:*",
    "@platform/rabbitmq-client": "workspace:*",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@fastify/multipart": "^9.0.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "prisma": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
